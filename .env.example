# =============================================================
# AGENT APP — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is listed in .gitignore.
# =============================================================

# ── Cloudinary (Image/Video Upload) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_API_KEY=your_cloudinary_api_key
# IMPORTANT: CLOUDINARY_API_SECRET is a server-side secret.
# Never use it in a Flutter/mobile app frontend.
# Keep it only in your backend/server environment.

# ── Paystack (Payments) ───────────────────────────────────────
# Use only the PUBLIC key in the app — never the secret key.
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── API Base URL (Backend) ────────────────────────────────────
API_BASE_URL=https://your-backend-api.com

# ── AI / OpenAI (if used) ─────────────────────────────────────
# WARNING: Never embed AI secret keys in a mobile app.
# Route all AI calls through your backend instead.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
